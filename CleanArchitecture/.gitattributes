# Auto detect text files and perform LF normalization
* text=auto

# Standard .NET source files
*.cs text diff=csharp
*.sln text eol=crlf
*.slnx text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.config text eol=lf

# Documentation and metadata
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.dockerignore text eol=lf

# Frontend (if any)
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=lf
